#!/usr/bin/env bash
set -euo pipefail

MENU="/usr/local/share/av-vault-os/launcher-menu.txt"

clear
if [[ -f /etc/motd ]]; then
  cat /etc/motd
fi

echo
if [[ -f "$MENU" ]]; then
  cat "$MENU"
else
  cat <<'MENU'
AV Vault Launcher

1. Open AV Ledger
2. Open AV Records
3. Open AV Assets
4. Open AV Evidence
5. Settings
6. Shutdown
MENU
fi

echo
read -r -p "Select an option: " choice

case "$choice" in
  1) echo "AV Ledger is not installed in this prototype." ;;
  2) echo "AV Records is not installed in this prototype." ;;
  3) echo "AV Assets is not installed in this prototype." ;;
  4) echo "AV Evidence is not installed in this prototype." ;;
  5) echo "Settings are not available in this prototype." ;;
  6) sudo shutdown now ;;
  *) echo "Unknown option." ;;
esac
